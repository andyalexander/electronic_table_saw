  <property name="styleSheet">
   <string notr="true">QMainWindow { background-color: #2b2b2b; }
QGroupBox { border: 2px solid #555555; border-radius: 5px; margin-top: 20px; font-size: 11pt; font-weight: bold; color: #89b4fa; background-color: #2b2b2b; }
QGroupBox::title { subcontrol-origin: margin; subcontrol-position: top left; padding: 0 5px; left: 10px; }
QPushButton { background-color: #3c3f41; color: #f0f0f0; border: 1px solid #5a5a5a; border-radius: 4px; }
QPushButton:pressed { background-color: #4c5052; }
QPushButton:disabled { background-color: #2a2a2a; color: #666666; border-color: #3a3a3a; }
QPushButton#but_estop { background-color: #cc2222; color: white; font-size: 20pt; font-weight: bold; border: 3px solid #ff4444; border-radius: 6px; }
QPushButton#but_estop:pressed { background-color: #991111; }
QPushButton#but_enable { background-color: #226622; color: white; font-size: 18pt; font-weight: bold; border: 2px solid #44aa44; border-radius: 6px; }
QPushButton#but_jog_left, QPushButton#but_jog_right { background-color: #1a4e8a; color: white; font-size: 14pt; font-weight: bold; border: 2px solid #4488cc; border-radius: 6px; }
QPushButton#but_reboot, QPushButton#but_shutdown { color: #ff8888; font-size: 12pt; border-color: #aa4444; }
QLineEdit#txt_fence_calc { background-color: #1a1a1a; color: #00dd88; border: 2px solid #444444; border-radius: 3px; }
QLabel { color: #f0f0f0; background-color: transparent; }
QComboBox { background-color: #3c3f41; color: #f0f0f0; border: 1px solid #5a5a5a; border-radius: 4px; font-size: 16pt; }
QRadioButton { color: #f0f0f0; font-size: 13pt; background-color: transparent; }
QFrame#frame { border: 1px solid #444444; border-radius: 3px; background-color: #252525; }</string>
  </property>
